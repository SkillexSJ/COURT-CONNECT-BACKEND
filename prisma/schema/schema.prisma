
generator client {
  provider        = "prisma-client"
  output          = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum UserRole {
  USER
  ORGANIZER
  ADMIN
}

enum CourtStatus {
  PENDING_APPROVAL
  ACTIVE
  MAINTENANCE
  HIDDEN
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  COMPLETED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum AnnouncementType {
  INFO
  MAINTENANCE
  PROMOTION
}



// --- BUSINESS LOGIC MODELS ---





model Coupon {
  id                String       @id @default(uuid()) @db.Uuid
  code              String       @unique // e.g., "WELCOME10"
  discountType      DiscountType
  discountValue     Decimal      @db.Decimal(12, 2)
  
  // Constraints
  minBookingAmount  Decimal?     @db.Decimal(12, 2) // "Only for bookings over $50"
  maxDiscountAmount Decimal?     @db.Decimal(12, 2) // "Max discount $20" (for percentage)
  usageLimit        Int?         // Total number of times this coupon can be used
  usedCount         Int          @default(0)
  
  expiresAt         DateTime?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())

  // Relations
  bookings          Booking[]    // Track which bookings used this coupon

  @@map("coupons")
}

model Announcement {
  id          String           @id @default(uuid()) @db.Uuid
  title       String
  content     String           @db.Text
  type        AnnouncementType @default(INFO)
  imageUrl    String?
  isPublished Boolean          @default(false)
  publishedAt DateTime?        @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("announcements")
}