
generator client {
  provider        = "prisma-client"
  output          = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MEMBER
  ORGANIZER
  ADMIN
}

enum CourtStatus {
  ACTIVE
  MAINTENANCE
  ARCHIVED
}

enum AssetType {
  IMAGE
  VIDEO
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  PAYMENT_PENDING
  PAID
  CANCELLED
  COMPLETED
  EXPIRED
}

enum PaymentIntentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  PROCESSING
  SUCCEEDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum CourtMemberStatus {
  ACTIVE
  LEFT
  BLOCKED
}

enum CourtMemberSource {
  BOOKING_APPROVED
  MANUAL
  PROMOTION
}



model Court {
  id            String             @id @default(uuid()) @db.Uuid
  organizerId   String             @db.Uuid
  slug          String             @unique
  name          String
  type          String
  surface       String
  locationLabel String
  description   String?
  basePrice     Decimal            @db.Decimal(12, 2)
  currency      String
  capacity      Int
  status        CourtStatus        @default(ACTIVE)
  isIndoor      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  organizer     User               @relation("CourtOrganizer", fields: [organizerId], references: [id], onDelete: Restrict)
  media         CourtMedia[]
  amenities     CourtAmenity[]
  slotTemplates CourtSlotTemplate[]
  closures      CourtClosure[]
  bookings      Booking[]
  bookingSlots  BookingSlot[]
  members       CourtMember[]

  @@index([organizerId])
  @@map("courts")
}

model CourtMember {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  courtId   String           @db.Uuid
  joinedAt  DateTime         @default(now())
  status    CourtMemberStatus @default(ACTIVE)
  source    CourtMemberSource @default(BOOKING_APPROVED)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  court     Court            @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([userId, courtId])
  @@index([courtId, status])
  @@index([userId, status])
  @@map("court_members")
}

model CourtMedia {
  id                String    @id @default(uuid()) @db.Uuid
  courtId           String    @db.Uuid
  uploadedById      String?   @db.Uuid
  assetType         AssetType
  resourceType      String
  url               String
  secureUrl         String
  cloudinaryPublicId String   @unique
  width             Int?
  height            Int?
  bytes             Int?
  isPrimary         Boolean   @default(false)
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())

  court             Court     @relation(fields: [courtId], references: [id], onDelete: Cascade)
  uploadedBy        User?     @relation("CourtMediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([courtId])
  @@index([uploadedById])
  @@map("court_media")
}

model Amenity {
  id        String        @id @default(uuid()) @db.Uuid
  slug      String        @unique
  name      String
  icon      String?
  createdAt DateTime      @default(now())

  courts    CourtAmenity[]

  @@map("amenities")
}

model CourtAmenity {
  courtId   String   @db.Uuid
  amenityId String   @db.Uuid
  createdAt DateTime @default(now())

  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  amenity   Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([courtId, amenityId])
  @@map("court_amenities")
}

model CourtSlotTemplate {
  id            String    @id @default(uuid()) @db.Uuid
  courtId       String    @db.Uuid
  dayOfWeek     Int
  startMinute   Int
  endMinute     Int
  priceOverride Decimal?  @db.Decimal(12, 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  court         Court     @relation(fields: [courtId], references: [id], onDelete: Cascade)
  bookingSlots  BookingSlot[]

  @@index([courtId, dayOfWeek, startMinute, endMinute])
  @@map("court_slot_templates")
}

model CourtClosure {
  id          String   @id @default(uuid()) @db.Uuid
  courtId     String   @db.Uuid
  closureDate DateTime @db.Date
  startMinute Int
  endMinute   Int
  reason      String?
  createdAt   DateTime @default(now())

  court       Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId, closureDate, startMinute, endMinute])
  @@map("court_closures")
}

model Booking {
  id             String                 @id @default(uuid()) @db.Uuid
  bookingCode    String                 @unique
  userId         String                 @db.Uuid
  courtId        String                 @db.Uuid
  couponId       String?                @db.Uuid
  approvedById   String?                @db.Uuid
  bookingDate    DateTime               @db.Date
  status         BookingStatus          @default(PENDING)
  subtotal       Decimal                @db.Decimal(12, 2)
  discountAmount Decimal                @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal                @db.Decimal(12, 2)
  currency       String
  notes          String?
  approvedAt     DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  user           User                   @relation("BookingUser", fields: [userId], references: [id], onDelete: Restrict)
  approvedBy     User?                  @relation("BookingApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  court          Court                  @relation(fields: [courtId], references: [id], onDelete: Restrict)
  coupon         Coupon?                @relation(fields: [couponId], references: [id], onDelete: SetNull)
  slots          BookingSlot[]
  statusHistory  BookingStatusHistory[]
  paymentIntent  PaymentIntent?
  payments       Payment[]
  redemptions    CouponRedemption[]
  refunds        Refund[]

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([courtId, bookingDate, status])
  @@map("bookings")
}

model BookingSlot {
  id             String            @id @default(uuid()) @db.Uuid
  bookingId      String            @db.Uuid
  courtId        String            @db.Uuid
  slotTemplateId String            @db.Uuid
  bookingDate    DateTime          @db.Date
  startMinute    Int
  endMinute      Int
  unitPrice      Decimal           @db.Decimal(12, 2)
  createdAt      DateTime          @default(now())

  booking        Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  court          Court             @relation(fields: [courtId], references: [id], onDelete: Restrict)
  slotTemplate   CourtSlotTemplate @relation(fields: [slotTemplateId], references: [id], onDelete: Restrict)

  @@unique([courtId, bookingDate, startMinute, endMinute])
  @@index([bookingId])
  @@index([slotTemplateId])
  @@map("booking_slots")
}

model BookingStatusHistory {
  id         String        @id @default(uuid()) @db.Uuid
  bookingId  String        @db.Uuid
  changedById String?      @db.Uuid
  fromStatus BookingStatus?
  toStatus   BookingStatus
  reason     String?
  createdAt  DateTime      @default(now())

  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy  User?         @relation("BookingStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt(sort: Desc)])
  @@index([changedById])
  @@map("booking_status_history")
}

model Coupon {
  id                String             @id @default(uuid()) @db.Uuid
  createdById       String?            @db.Uuid
  code              String             @unique
  discountType      DiscountType
  discountValue     Decimal            @db.Decimal(12, 2)
  maxDiscountAmount Decimal?           @db.Decimal(12, 2)
  minOrderAmount    Decimal?           @db.Decimal(12, 2)
  usageLimit        Int?
  usageCount        Int                @default(0)
  perUserLimit      Int?
  startsOn          DateTime?          @db.Date
  expiresOn         DateTime?          @db.Date
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  createdBy         User?               @relation("CouponCreator", fields: [createdById], references: [id], onDelete: SetNull)
  bookings          Booking[]
  payments          Payment[]
  redemptions       CouponRedemption[]

  @@index([createdById])
  @@index([isActive, startsOn, expiresOn])
  @@map("coupons")
}

model CouponRedemption {
  id             String    @id @default(uuid()) @db.Uuid
  couponId       String    @db.Uuid
  userId         String    @db.Uuid
  bookingId      String?   @db.Uuid
  paymentId      String?   @unique @db.Uuid
  discountAmount Decimal   @db.Decimal(12, 2)
  redeemedAt     DateTime  @default(now())

  user           User      @relation("CouponRedemptionUser", fields: [userId], references: [id], onDelete: Restrict)
  coupon         Coupon    @relation(fields: [couponId], references: [id], onDelete: Restrict)
  booking        Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  payment        Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([couponId, userId])
  @@index([userId])
  @@index([bookingId])
  @@map("coupon_redemptions")
}

model PaymentIntent {
  id               String              @id @default(uuid()) @db.Uuid
  bookingId        String              @unique @db.Uuid
  userId           String              @db.Uuid
  provider         String
  providerIntentId String              @unique
  amount           Decimal             @db.Decimal(12, 2)
  currency         String
  status           PaymentIntentStatus @default(REQUIRES_PAYMENT_METHOD)
  expiresAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user             User                @relation("PaymentIntentUser", fields: [userId], references: [id], onDelete: Restrict)
  booking          Booking             @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  payment          Payment?

  @@index([userId, createdAt(sort: Desc)])
  @@map("payment_intents")
}

model Payment {
  id                String             @id @default(uuid()) @db.Uuid
  bookingId         String             @db.Uuid
  userId            String             @db.Uuid
  couponId          String?            @db.Uuid
  paymentIntentId   String?            @unique @db.Uuid
  provider          String
  providerPaymentId String             @unique
  chargeId          String?
  receiptUrl        String?
  methodType        String?
  status            PaymentStatus      @default(PENDING)
  amount            Decimal            @db.Decimal(12, 2)
  discountAmount    Decimal            @default(0) @db.Decimal(12, 2)
  netAmount         Decimal            @db.Decimal(12, 2)
  currency          String
  paidAt            DateTime?
  createdAt         DateTime           @default(now())

  user              User               @relation("PaymentUser", fields: [userId], references: [id], onDelete: Restrict)
  booking           Booking            @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  coupon            Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  paymentIntent     PaymentIntent?     @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  refunds           Refund[]
  redemption        CouponRedemption?

  @@index([userId, paidAt(sort: Desc)])
  @@index([bookingId, status])
  @@map("payments")
}

model Refund {
  id               String        @id @default(uuid()) @db.Uuid
  paymentId        String        @db.Uuid
  bookingId        String        @db.Uuid
  approvedById     String?       @db.Uuid
  providerRefundId String        @unique
  amount           Decimal       @db.Decimal(12, 2)
  reason           String?
  status           RefundStatus  @default(PENDING)
  createdAt        DateTime      @default(now())
  processedAt      DateTime?

  approvedBy       User?         @relation("RefundApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  payment          Payment       @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  booking          Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([approvedById])
  @@index([paymentId, createdAt(sort: Desc)])
  @@index([bookingId])
  @@map("refunds")
}

model PaymentWebhookEvent {
  id               String                  @id @default(uuid()) @db.Uuid
  provider         String
  providerEventId  String                  @unique
  eventType        String
  processingStatus WebhookProcessingStatus @default(RECEIVED)
  payload          Json
  processedAt      DateTime?
  createdAt        DateTime                @default(now())

  @@index([provider, eventType])
  @@map("payment_webhook_events")
}

model Announcement {
  id             String    @id @default(uuid()) @db.Uuid
  publishedById  String?   @db.Uuid
  title          String
  slug           String    @unique
  content        String
  coverImageUrl  String?
  coverPublicId  String?
  isPinned       Boolean   @default(false)
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  publishedBy    User?     @relation("AnnouncementPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  @@index([publishedById])
  @@index([isPublished, publishedAt(sort: Desc)])
  @@map("announcements")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorUserId String? @db.Uuid
  entityType String
  entityId   String
  action     String
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor      User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("audit_logs")
}
